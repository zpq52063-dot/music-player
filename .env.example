# ==================== Phase 9 — Environment Configuration ====================
# 复制此文件为 .env.local 并填入真实值

# ==================== Supabase ====================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==================== Provider Env ====================
# 当前使用内置 mock demo 歌曲 (SoundHelix public MP3)
# 后续接入真实音源时在此配置

# ==================== Debug Env ====================
# Release Mode: debug | internal | release
NEXT_PUBLIC_RELEASE_MODE=debug

# Debug Overlay 开启 (仅debug模式生效)
NEXT_PUBLIC_DEBUG_OVERLAY=true

# Logger 默认分类 (debug模式下)
NEXT_PUBLIC_LOG_CATEGORIES=audio,provider,playback,cache,debug

# ==================== Cache Env ====================
# 缓存治理间隔 (ms, 默认600000 = 10min)
NEXT_PUBLIC_CACHE_CLEANUP_INTERVAL=600000

# 歌词最大保留天数
NEXT_PUBLIC_LYRIC_MAX_AGE_DAYS=7

# 播放历史最大条数
NEXT_PUBLIC_HISTORY_MAX_ENTRIES=500

# 元数据最大保留天数
NEXT_PUBLIC_METADATA_MAX_AGE_DAYS=30

# ==================== Recovery Env ====================
# 看门狗检测间隔 (ms)
NEXT_PUBLIC_WATCHDOG_INTERVAL=2000

# 卡顿检测阈值 (ms, currentTime无变化)
NEXT_PUBLIC_WATCHDOG_STALL_THRESHOLD=5000

# 加载超时阈值 (ms)
NEXT_PUBLIC_WATCHDOG_TIMEOUT_THRESHOLD=30000

# Provider自愈降级阈值 (0-100)
NEXT_PUBLIC_SELF_HEALING_DEGRADE_THRESHOLD=30

# Provider自愈恢复探测间隔 (ms)
NEXT_PUBLIC_SELF_HEALING_PROBE_INTERVAL=30000

# ==================== Performance Env ====================
# 性能清理间隔 (ms)
NEXT_PUBLIC_CLEANUP_INTERVAL=600000

# 音频空闲超时 (ms, 5min)
NEXT_PUBLIC_AUDIO_IDLE_TIMEOUT=300000

# ==================== Telemetry Env ====================
# 遥测开关 (release模式默认关闭)
NEXT_PUBLIC_TELEMETRY_ENABLED=true

# 遥测数据最大条目数
NEXT_PUBLIC_TELEMETRY_MAX_ENTRIES=1000

# ==================== Phase 16B — Remote Provider ====================
# Cloudflare Worker URL (metadata/search proxy, no audio relay)
# Deploy with: npx wrangler deploy
# Leave empty to use built-in mock data only
NEXT_PUBLIC_CF_WORKER_URL=

# ==================== Vercel ====================
# Vercel 自动注入, 无需手动设置
# VERCEL_URL
# VERCEL_ENV
