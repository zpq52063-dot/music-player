# ==================== Phase 20A — Production Environment ====================
# 复制此文件为 .env.production 并填入真实值
# Cloudflare Pages 生产环境

# ==================== Deploy Mode ====================
NEXT_PUBLIC_RELEASE_MODE=release

# Custom domain (REQUIRED for production — PWA needs canonical URL)
NEXT_PUBLIC_SITE_URL=https://music.example.com

# ==================== Cloudflare Worker ====================
NEXT_PUBLIC_CF_WORKER_URL=https://music-proxy.example.workers.dev

# ==================== Supabase (Optional) ====================
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ==================== Feature Flags (Production) ====================
# Production: ALL debug features OFF
# Diagnostics OFF, Debug Overlay OFF, Telemetry OFF
# Safety banner hidden
NEXT_PUBLIC_DEBUG_OVERLAY=false
NEXT_PUBLIC_TELEMETRY_ENABLED=false
