# ==================== Phase 20A — Preview Environment ====================
# 复制此文件为 .env.preview 并填入真实值
# Cloudflare Pages 预览部署环境

# ==================== Deploy Mode ====================
NEXT_PUBLIC_RELEASE_MODE=internal

# Custom domain / preview URL (set by Cloudflare Pages automatically)
# CF_PAGES_URL is injected by Cloudflare Pages at build time
# NEXT_PUBLIC_SITE_URL is for custom domain override (leave empty for auto-detect)
NEXT_PUBLIC_SITE_URL=

# ==================== Cloudflare Worker ====================
NEXT_PUBLIC_CF_WORKER_URL=https://music-proxy-preview.<your-subdomain>.workers.dev

# ==================== Supabase (Optional) ====================
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ==================== Feature Flags (Preview) ====================
# Preview: diagnostics OFF (unless password-gated), debug overlay OFF
# Telemetry: enabled but local-only (no external send)
NEXT_PUBLIC_DEBUG_OVERLAY=false
NEXT_PUBLIC_TELEMETRY_ENABLED=true
